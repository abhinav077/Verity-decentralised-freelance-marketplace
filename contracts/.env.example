# ============================================================
# REQUIRED — Wallet private key for deploying contracts
# ============================================================
# Export from MetaMask: Account Details → Export Private Key
# NEVER commit the real key! Add .env to .gitignore.
PRIVATE_KEY=your_private_key_here

# ============================================================
# TESTNET RPC URLs (pick one — Amoy recommended)
# ============================================================
# Polygon Amoy (recommended) — get faucet tokens at https://faucet.polygon.technology/
POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Base Sepolia — get faucet tokens at https://www.alchemy.com/faucets/base-sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Ethereum Sepolia — get free RPC from https://alchemy.com
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# ============================================================
# MAINNET (optional)
# ============================================================
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com
REPORT_GAS=true