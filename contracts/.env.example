# ============================================================
# REQUIRED FOR SEPOLIA DEPLOYMENT
# ============================================================

# Your MetaMask wallet private key (NEVER commit the real one!)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# Sepolia RPC URL — get free one from https://alchemy.com
# Create account → New App → Ethereum Sepolia → copy HTTPS URL
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key_here

# ============================================================
# OPTIONAL (polygon networks)
# ============================================================
POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
POLYGON_MAINNET_RPC_URL=https://polygon-rpc.com
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here
REPORT_GAS=true